# Server Configuration
PORT=3001

# Database Configuration
# Connection pool settings:
# - connection_limit: Maximum number of connections in the pool (default: 10)
# - pool_timeout: Maximum time (in seconds) to wait for a connection from the pool (default: 5)
# - connect_timeout: Maximum time (in seconds) to wait for a new connection (default: 5)
DATABASE_URL=postgresql://wallet_user:wallet_pass@postgres:5432/wallets?connection_limit=10&pool_timeout=5&connect_timeout=5

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_BET_PLACED_QUEUE=bet.placed
RABBITMQ_CASHOUT_QUEUE=bet.cashout
RABBITMQ_BET_LOST_QUEUE=bet.lost
RABBITMQ_GAME_EXCHANGE=game.events
RABBITMQ_WALLET_EXCHANGE=wallet.events

# JWT Configuration
JWT_SECRET=shared-secret-from-keycloak
JWT_ISSUER=http://keycloak:8080/realms/crash-game

# Logging Configuration
LOG_LEVEL=info

# Environment
NODE_ENV=development
