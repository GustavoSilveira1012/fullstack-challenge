# Environment Variables Template
# Copy this file to .env.development or .env.production and fill in the values

# API URLs (via Kong API Gateway)
VITE_API_URL=http://localhost:8000
VITE_WALLET_API_URL=http://localhost:8000
VITE_KEYCLOAK_URL=http://localhost:8080

# Keycloak Configuration
VITE_KEYCLOAK_REALM=crash-game
VITE_KEYCLOAK_CLIENT_ID=crash-game-client

# WebSocket URL (via Kong)
VITE_WS_URL=ws://localhost:8000

# Logging Level (debug, info, warn, error)
VITE_LOG_LEVEL=debug
