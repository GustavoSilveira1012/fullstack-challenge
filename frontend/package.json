{
  "name": "crash-game-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --project tsconfig.build.json && vite build",
    "build:analyze": "ANALYZE=true npm run build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:a11y": "axe-core --exit --tags wcag2a,wcag2aa http://localhost:4173",
    "perf:lighthouse": "lighthouse http://localhost:4173 --output=html --output-path=./lighthouse-report.html",
    "perf:bundle-size": "npm run build:analyze",
    "optimize:images": "echo 'Run image optimization tools here'",
    "compress": "gzip -9 -c dist/assets/js/*.js > dist/assets/js/compressed.js.gz",
    "deploy:vercel": "vercel --prod",
    "deploy:netlify": "netlify deploy --prod --dir=dist",
    "health:check": "node -e \"fetch('http://localhost:4173').then(r => r.ok ? console.log('✅ Healthy') : console.log('❌ Unhealthy'))\"",
    "monitor:start": "node scripts/monitor.js",
    "security:audit": "npm audit --audit-level=moderate",
    "security:snyk": "snyk test --severity-threshold=high",
    "docs:serve": "npx http-server docs -p 8080",
    "clean": "rm -rf dist coverage .nyc_output node_modules/.cache"
  },
  "dependencies": {
    "@sentry/react": "^10.51.0",
    "@sentry/tracing": "^7.120.4",
    "axios": "^1.6.2",
    "dompurify": "^3.0.6",
    "lucide-react": "^1.14.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.3",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.0.4",
    "@vitest/ui": "^1.0.4",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.54.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "fast-check": "^3.14.0",
    "history": "^5.3.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.31",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^1.0.4"
  }
}
